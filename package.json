{
  "name": "archmate",
  "version": "1.0.0",
  "description": "Auto-generate architecture diagrams from source code using AST parsing and static analysis",
  "main": "dist/index.js",
  "bin": {
    "archmate": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "architecture",
    "diagram",
    "uml",
    "c4",
    "plantuml",
    "mermaid",
    "static-analysis",
    "ast",
    "code-analysis",
    "visualization"
  ],
  "author": "ArchMate Team",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "d3": "^7.9.0",
    "d3-hierarchy": "^3.1.2",
    "fs-extra": "^11.2.0",
    "graphlib": "^2.1.8",
    "puppeteer": "^22.0.0",
    "typescript": "^5.4.0",
    "typescript-json-schema": "^0.62.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/fs-extra": "^11.0.4",
    "@types/graphlib": "^2.1.12",
    "@types/node": "^20.11.0",
    "@types/puppeteer": "^7.0.4",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
